/**index.wxss**/
page {
  height: 100vh;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F5F5 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
}

/* 标题区 */
.title-section {
  padding: 30rpx 20rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.main-title-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.main-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #000;
  flex: 1;
}

.title-image {
  width: 120rpx;
  height: 120rpx;
}

.action-button {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1976D2 0%, #42A5F5 100%);
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(25, 118, 210, 0.3);
  position: relative;
}

.button-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

.arrow-decor {
  position: absolute;
  right: 20rpx;
  color: #FFD700;
  font-size: 24rpx;
  font-weight: bold;
}

.hint-text {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.hint-icon {
  font-size: 24rpx;
}

.hint-content {
  font-size: 24rpx;
  color: #999;
}

/* 功能区 */
.function-section {
  padding: 20rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.function-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.function-card {
  flex: 1;
  background: linear-gradient(135deg, #42A5F5 0%, #64B5F6 100%);
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(66, 165, 245, 0.3);
}

.function-card.primary {
  background: linear-gradient(135deg, #2196F3 0%, #42A5F5 100%);
}

.card-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
  display: block;
}

.card-image {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.card-arrow {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* 功能图标网格 */
.icon-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.icon-item {
  width: calc(20% - 16rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
  background: #fff;
  border: 2rpx solid #E3F2FD;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.icon-wrapper {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F5F5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.icon {
  font-size: 32rpx;
}

.icon-label {
  font-size: 24rpx;
  color: #000;
  text-align: center;
}

/* 优惠区 */
.discount-section {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.discount-card {
  flex: 1;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F5F5 100%);
  border-radius: 20rpx;
  padding: 20rpx;
  position: relative;
  border: 2rpx solid #BBDEFB;
}

.discount-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #000;
  margin-bottom: 10rpx;
  display: block;
}

.discount-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #1976D2;
  margin-bottom: 15rpx;
  display: block;
}

.discount-image {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 15rpx;
}

.purchase-btn {
  background: linear-gradient(135deg, #1976D2 0%, #42A5F5 100%);
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 25rpx;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(25, 118, 210, 0.3);
}

/* 底部横幅 */
.bottom-banner {
  width: 100%;
  margin: 0;
  padding: 0;
  background: transparent;
  border-radius: 0;
  box-shadow: none;
}

.banner-image {
  width: 100%;
  height: auto;
  display: block;
}
