/**index.wxss**/
page {
  height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  background: #F8FBFC; /* 极淡的浅蓝色背景 */
  background-image: url('https://semhaq.github.io/community_service/images/top-banner.png');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  background-attachment: fixed;
}

/* 新增：整体容器白色大背景 */
.function-section {
  background: #FFFFFF; /* 纯白色背景 */
  border-radius: 24rpx; /* 大圆角 */
  padding: 20rpx 20rpx 20rpx; /* 上边距20rpx，左右20rpx，底部20rpx */
  margin: 0 20rpx 20rpx; /* 左右边距20rpx，底部20rpx */
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03); /* 极柔和的弥散阴影 */
}

.scrollarea {
  height: 100vh;
  overflow-y: auto;
  padding-bottom: 180rpx;
  box-sizing: border-box;
  background: transparent;
}

.top-space {
  height: 550rpx; /* 顶部占位空间高度，您可以根据需要调整 */
}

.function-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx; /* 和下方网格的间距 */
  margin-top: -60rpx; /* 向上移动更多，让卡片部分重叠在白色容器上 */
  position: relative; /* 确保卡片在白色容器上方 */
  z-index: 1; /* 确保卡片显示在白色容器上面 */
}

.function-card {
  flex: 1;
  background: transparent; /* 透明背景 */
  border-radius: 20rpx;
  padding: 0; /* 去掉内边距 */
  position: relative;
  box-shadow: none; /* 去掉阴影 */
  overflow: hidden; /* 确保图片圆角生效 */
  margin-top: -50rpx; /* 每个卡片向上移动，部分重叠在白色容器上 */
}

.function-card.primary {
  background: transparent; /* 透明背景，两个卡片样式统一 */
}

/* 卡片内图片样式 */
.card-full-image {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 20rpx; /* 继承卡片圆角 */
  margin: -10rpx; /* 图片向外扩展，让卡片看起来更大 */
  width: calc(100% + 20rpx); /* 图片宽度增加 */
}

/* 功能图标网格 */
.icon-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx; /* 列间距16rpx，更紧凑 */
  row-gap: 24rpx; /* 行间距24rpx，更紧凑 */
}

.icon-item {
  width: calc(20% - 16rpx); /* 5列布局 */
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0; /* 去掉内边距 */
  background: transparent; /* 透明背景 */
  border: none; /* 无边框 */
  box-sizing: border-box;
}

/* 图标样式精准还原 */
.service-icon {
  width: 80rpx; /* 图标尺寸80rpx * 80rpx */
  height: 80rpx;
  margin-bottom: 12rpx; /* 和文字的间距 */
  background: transparent; /* 确保图标背景透明 */
  border-radius: 0; /* 确保无圆角 */
}

.icon-label {
  font-size: 24rpx; /* 字号24rpx */
  font-weight: 500; /* 字重500 */
  color: #333333; /* 颜色#333333 */
  text-align: center;
  line-height: 1.2; /* 行高1.2倍 */
}

/* 优惠区 */
.discount-section {
  display: flex;
  padding: 20rpx;
  background: transparent;
  margin-bottom: 20rpx;
}

.discount-card {
  flex: 1;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F5F5 100%);
  border-radius: 16rpx;
  padding: 15rpx;
  position: relative;
  border: 2rpx solid #BBDEFB;
  min-width: 0; /* 解决flex布局内容溢出的问题 */
  display: flex;
  flex-direction: column;
}

.discount-card:first-child {
  margin-right: 10rpx;
}

.discount-card:last-child {
  margin-left: 10rpx;
}

.discount-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #000;
  margin-bottom: 8rpx;
  display: block;
}

.discount-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #1976D2;
  margin-bottom: 10rpx;
  display: block;
}

.discount-image {
  width: 50rpx;
  height: 50rpx;
  margin-bottom: 10rpx;
}

.purchase-btn {
  background: linear-gradient(135deg, #1976D2 0%, #42A5F5 100%);
  color: #fff;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 25rpx;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(25, 118, 210, 0.3);
  margin-top: auto; /* 确保按钮在底部 */
  align-self: center; /* 水平居中 */
  text-align: center; /* 文字居中 */
  width: auto; /* 自动宽度 */
  max-width: 80%; /* 最大宽度限制 */
  box-sizing: border-box;
}

/* 底部横幅 */
.bottom-banner {
  width: 100%;
  margin: 0;
  padding: 0;
  background: transparent;
  border-radius: 0;
  box-shadow: none;
}

.banner-image {
  width: 100%;
  height: auto;
  display: block;
}