/**index.wxss**/
page {
  height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  background-image: url('https://semhaq.github.io/community_service/images/top-banner.png');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  background-attachment: fixed; /* 固定背景，不滚动 */
}

.scrollarea {
  height: 100vh;
  overflow-y: auto;
  padding-bottom: 180rpx;
  box-sizing: border-box;
  background: transparent;
}

.top-space {
  height: 400rpx; /* 顶部占位空间高度，您可以根据需要调整 */
}

/* 标题区 */
.title-section {
  padding: 30rpx 20rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.main-title-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.main-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #000;
  flex: 1;
}

.title-image {
  width: 120rpx;
  height: 120rpx;
}

.action-button {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1976D2 0%, #42A5F5 100%);
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(25, 118, 210, 0.3);
  position: relative;
}

.button-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

.arrow-decor {
  position: absolute;
  right: 20rpx;
  color: #FFD700;
  font-size: 24rpx;
  font-weight: bold;
}

.hint-text {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.hint-icon {
  font-size: 24rpx;
}

.hint-content {
  font-size: 24rpx;
  color: #999;
}

/* 功能区 */
.function-section {
  padding: 20rpx;
  background: transparent;
  margin-bottom: 20rpx;
}

.function-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.function-card {
  flex: 1;
  background: transparent; /* 改为透明背景 */
  border-radius: 20rpx;
  padding: 0; /* 去掉内边距 */
  position: relative;
  box-shadow: none; /* 去掉阴影 */
  overflow: hidden; /* 确保图片圆角生效 */
}

.function-card.primary {
  background: transparent; /* 改为透明背景 */
}

/* 新增：卡片内图片样式 */
.card-full-image {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 20rpx; /* 继承卡片圆角 */
}

/* 功能图标网格 */
.icon-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.icon-item {
  width: calc(20% - 16rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
  background: transparent; /* 去掉白色背景 */
  border: none; /* 去掉边框 */
  border-radius: 0; /* 去掉圆角 */
  box-sizing: border-box;
}

/* 移除.icon-wrapper相关样式，因为我们已经在WXML中移除了这一层 */

.service-icon {
  width: 60rpx; /* 调整图标尺寸 */
  height: 60rpx;
  margin-bottom: 12rpx;
}

.icon-label {
  font-size: 24rpx;
  color: #000;
  text-align: center;
}

/* 优惠区 */
.discount-section {
  display: flex;
  padding: 20rpx;
  background: transparent;
  margin-bottom: 20rpx;
}

.discount-card {
  flex: 1;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F5F5 100%);
  border-radius: 16rpx;
  padding: 15rpx;
  position: relative;
  border: 2rpx solid #BBDEFB;
  min-width: 0; /* 解决flex布局内容溢出的问题 */
  display: flex;
  flex-direction: column;
}

.discount-card:first-child {
  margin-right: 10rpx;
}

.discount-card:last-child {
  margin-left: 10rpx;
}

.discount-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #000;
  margin-bottom: 8rpx;
  display: block;
}

.discount-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #1976D2;
  margin-bottom: 10rpx;
  display: block;
}

.discount-image {
  width: 50rpx;
  height: 50rpx;
  margin-bottom: 10rpx;
}

.purchase-btn {
  background: linear-gradient(135deg, #1976D2 0%, #42A5F5 100%);
  color: #fff;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 25rpx;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(25, 118, 210, 0.3);
  margin-top: auto; /* 确保按钮在底部 */
  align-self: center; /* 水平居中 */
  text-align: center; /* 文字居中 */
  width: auto; /* 自动宽度 */
  max-width: 80%; /* 最大宽度限制 */
  box-sizing: border-box;
}

/* 底部横幅 */
.bottom-banner {
  width: 100%;
  margin: 0;
  padding: 0;
  background: transparent;
  border-radius: 0;
  box-shadow: none;
}

.banner-image {
  width: 100%;
  height: auto;
  display: block;
}
