<navigation-bar title="社区服务小程序" back="{{false}}" homeButton="{{false}}" loading="{{false}}" />

<!-- 固定背景层 -->
<view class="fixed-background"></view>

<scroll-view class="scrollarea" scroll-y>
  <!-- 顶部占位空间 -->
  <view class="top-space"></view>

  <!-- 功能区 -->
  <view class="function-section">
    <view class="function-row">
      <view class="function-card primary" bindtap="navigateToHelp">
        <!-- 顶部双大卡片改为纯图片展示，保留点击事件 -->
        <image class="card-full-image" src="https://semhaq.github.io/community_service/images/help_func.png" mode="widthFix"></image>
      </view>

      <view class="function-card" bindtap="navigateToDelivery">
        <!-- 顶部双大卡片改为纯图片展示，保留点击事件 -->
        <image class="card-full-image" src="https://semhaq.github.io/community_service/images/express_func.png" mode="widthFix"></image>
      </view>
    </view>

    <!-- 功能图标网格 -->
    <view class="icon-grid">
      <view class="icon-item" wx:for="{{services}}" wx:key="name" bindtap="serviceClick" data-service="{{item.name}}">
        <!-- 移除icon-wrapper层，直接放置图标 -->
        <image class="service-icon" src="{{item.icon}}" mode="aspectFit"></image>
        <text class="icon-label">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 优惠区 -->
  <view class="discount-section">
    <view class="discount-card" bindtap="purchaseCard" data-type="feeding">
      <text class="discount-title">喂养卡</text>
      <text class="discount-price">¥15/次</text>
      <image class="discount-image" src="https://semhaq.github.io/community_service/images/pet-feeding.png" mode="aspectFit"></image>
      <button class="purchase-btn">去开卡</button>
    </view>

    <view class="discount-card" bindtap="purchaseCard" data-type="dryclean">
      <text class="discount-title">干洗卡</text>
      <text class="discount-price">¥25/次</text>
      <image class="discount-image" src="https://semhaq.github.io/community_service/images/dry-clean.png" mode="aspectFit"></image>
      <button class="purchase-btn">去开卡</button>
    </view>
  </view>


</scroll-view>
