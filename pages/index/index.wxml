<scroll-view class="scrollarea" scroll-y>
  <!-- 标题区 -->
  <view class="title-section">
    <view class="main-title-wrapper">
  <view class="title-text">
    <text class="title-line">社区万事通</text>
    <text class="title-line second-line">解忧分分钟</text>
  </view>
  <image class="title-image" src="/images/delivery-person.png" mode="aspectFit"></image>
</view>

<view class="action-button" bindtap="showOptions">
  <text class="button-text">速去下单 >></text>
</view>

  </view>

  <!-- 功能区 -->
  <view class="function-section">
    <view class="function-row">
      <view class="function-card primary" bindtap="navigateToHelp">
        <text class="card-title">互帮互助</text>
        <image class="card-image" src="/images/helping-hands.png" mode="aspectFit"></image>
        <view class="card-arrow">➤</view>
      </view>

      <view class="function-card" bindtap="navigateToDelivery">
        <text class="card-title">帮取快递</text>
        <image class="card-image" src="/images/package.png" mode="aspectFit"></image>
        <view class="card-arrow">➤</view>
      </view>
    </view>

    <!-- 功能图标网格 -->
    <view class="icon-grid">
      <view class="icon-item" wx:for="{{services}}" wx:key="name" bindtap="serviceClick" data-service="{{item.name}}">
        <view class="icon-wrapper">
          <image class="service-icon" src="{{item.icon}}" mode="aspectFit"></image>
        </view>
        <text class="icon-label">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 优惠区 -->
  <view class="discount-section">
    <view class="discount-card" bindtap="purchaseCard" data-type="feeding">
      <text class="discount-title">喂养卡</text>
      <text class="discount-price">¥15/次</text>
      <image class="discount-image" src="/images/pet-feeding.png" mode="aspectFit"></image>
      <button class="purchase-btn">去开卡</button>
    </view>

    <view class="discount-card" bindtap="purchaseCard" data-type="dryclean">
      <text class="discount-title">干洗卡</text>
      <text class="discount-price">¥25/次</text>
      <image class="discount-image" src="/images/dry-clean.png" mode="aspectFit"></image>
      <button class="purchase-btn">去开卡</button>
    </view>
  </view>

  <!-- 底部横幅 -->
  <view class="bottom-banner">
  <image class="banner-image" src="/images/bottom-banner.png" mode="aspectFill"></image>
</view>
</scroll-view>
